        "operationId": "AuthController_register",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponseDto"
                }
              }
            }
          }
        },
        "tags": [
          "auth"
        ]
      }
    },
    "/api/auth/login": {
      "post": {
        "operationId": "AuthController_login",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponseDto"
                }
              }
            }
          }
        },
        "tags": [
          "auth"
        ]
      }
    },
    "/api/files": {
      "post": {
        "operationId": "FilesController_upload",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "file"
                ],
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary"
                  },
                  "expiresInDays": {
                    "type": "integer"
                  },
                  "password": {
                    "type": "string"
                  },
                  "tags": {
                    "type": "string",
                    "description": "Tags séparés par des virgules"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UploadResultDto"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "tags": [
          "files"
        ]
      },
      "get": {
        "operationId": "FilesController_history",
        "parameters": [
          {
            "name": "tag",
            "required": true,
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/FileSummaryDto"
                  }
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "tags": [
          "files"
        ]
      }
    },
    "/api/files/{token}": {
      "get": {
        "operationId": "FilesController_metadata",
        "parameters": [
          {
            "name": "token",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FileMetadataDto"
                }
              }
            }
          }
        },
        "tags": [
          "files"
        ]
      }
    },
    "/api/files/{token}/verify": {
      "post": {
        "operationId": "FilesController_verify",
        "parameters": [
          {
            "name": "token",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VerifyPasswordDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VerifyPasswordResultDto"
                }
              }
            }
          }
        },
        "tags": [
          "files"
        ]
      }
    },
    "/api/files/{token}/download": {
      "get": {
        "operationId": "FilesController_download",
        "parameters": [
          {
            "name": "token",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "x-file-password",
            "required": false,
            "in": "header",
            "description": "Mot de passe du fichier protégé (US09) — transmis hors URL",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/octet-stream": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            },
            "description": ""
          }
        },
        "tags": [
          "files"
        ]
      }
    },
    "/api/files/{id}": {
      "delete": {
        "operationId": "FilesController_remove",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "tags": [
          "files"
        ]
      }
    },
    "/api/tags": {
      "get": {
        "operationId": "TagsController_list",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/TagSummaryDto"
                  }
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "tags": [
          "tags"
        ]
      }
    }
  },
  "info": {
    "title": "DataShare API",
    "description": "API de transfert de fichiers DataShare (US01-US10)",
    "version": "1.0.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "RegisterDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "user@datashare.app"
          },
          "password": {
            "type": "string",
            "minLength": 8,
            "example": "motdepasse123"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "UserDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "example": "user@datashare.app"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "email",
          "createdAt"
        ]
      },
      "AuthResponseDto": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string"
          },
          "user": {
            "$ref": "#/components/schemas/UserDto"
          }
        },
        "required": [
          "accessToken",
          "user"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "user@datashare.app"
          },
          "password": {
            "type": "string"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "UploadResultDto": {
        "type": "object",
        "properties": {
          "downloadToken": {
            "type": "string"
          },
          "downloadUrl": {
            "type": "string"
          },
          "originalName": {
            "type": "string"
          },
          "sizeBytes": {
            "type": "number"
          },
          "mimeType": {
            "type": "string"
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time"
          },
          "passwordProtected": {
            "type": "boolean"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "downloadToken",
          "downloadUrl",
          "originalName",
          "sizeBytes",
          "mimeType",
          "expiresAt",
          "passwordProtected",
          "tags"
        ]
      },
      "FileSummaryDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "originalName": {
            "type": "string"
          },
          "sizeBytes": {
            "type": "number"
          },
          "mimeType": {
            "type": "string"
          },
          "downloadToken": {
            "type": "string"
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "passwordProtected": {
            "type": "boolean"
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "expired"
            ]
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "id",
          "originalName",
          "sizeBytes",
          "mimeType",
          "downloadToken",
          "expiresAt",
          "createdAt",
          "passwordProtected",
          "status",
          "tags"
        ]
      },
      "FileMetadataDto": {
        "type": "object",
        "properties": {
          "originalName": {
            "type": "string"
          },
          "sizeBytes": {
            "type": "number"
          },
          "mimeType": {
            "type": "string"
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time"
          },
          "passwordProtected": {
            "type": "boolean"
          }
        },
        "required": [
          "originalName",
          "sizeBytes",
          "mimeType",
          "expiresAt",
          "passwordProtected"
        ]
      },
      "VerifyPasswordDto": {
        "type": "object",
        "properties": {
          "password": {
            "type": "string"
          }
        },
        "required": [
          "password"
        ]
      },
      "VerifyPasswordResultDto": {
        "type": "object",
        "properties": {
          "valid": {
            "type": "boolean"
          }
        },
        "required": [
          "valid"
        ]
      },
      "TagSummaryDto": {
        "type": "object",
        "properties": {
          "label": {
            "type": "string"
          },
          "count": {
            "type": "number"
          }
        },
        "required": [
          "label",
          "count"
        ]
      }
    }
  }
}